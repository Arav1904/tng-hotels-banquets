# Dependencies — never commit these (huge folders)
node_modules/
*/node_modules/
backend/node_modules/
frontend/node_modules/

# Environment variables — NEVER commit .env files (contains passwords/secrets)
.env
.env.local
.env.production
backend/.env
frontend/.env

# Build outputs
dist/
build/
frontend/dist/
frontend/build/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
logs/

# OS generated files
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini

# Editor files
.vscode/settings.json
.idea/
*.swp
*.swo
*.suo

# Vite cache
.vite/
frontend/.vite/

# Test files
coverage/
*.test.js.snap